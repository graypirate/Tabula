{
  "name": "@graypirate/tabula-mcp",
  "version": "1.0.1",
  "description": "Local stdio MCP server for Tabula.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "tabula-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod 755 dist/index.js",
    "prepublishOnly": "bun run typecheck && bun test && bun run build",
    "start": "bun src/index.ts",
    "test": "bun run --cwd ../core build && bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@graypirate/tabula": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "typescript": "^5"
  }
}
